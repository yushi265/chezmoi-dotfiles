[core]
    pager = delta

[pager]
    diff = delta
    log = delta
    reflog = delta
    show = delta

[delta]
    navigate = true
    light = false
    line-numbers = true
    syntax-theme = Monokai Extended

[interactive]
    diffFilter = delta --color-only

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default

[ghq]
    root = ~/src
